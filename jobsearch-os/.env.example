# jobsearch-os configuration — copy to .env and fill in as needed.
# Phase 1 needs NONE of these; the system runs fully with zero keys.

# --- Feature flags (Phases 7-8 only) ---
CLAUDE_CODE_ENABLED=false
HANDOFFS_ENABLED=false
CLAUDE_CODE_IMPLEMENTATION_ENABLED=false
CLAUDE_CHAT_MODE=handoff_only        # handoff_only | supported_direct_interface | user_attended_browser

# --- Model identifiers (Phase 3+; exact ids, never guessed) ---
CLAUDE_REVIEW_MODEL=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Paths / behavior overrides (optional; highest precedence is CLI args) ---
JOBSEARCH_DB_PATH=
JOBSEARCH_BUDGET_MODE=normal          # normal | conserve | critical | ai_paused
